generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String          @id @default(cuid())
  name             String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  stripeCustomerId String?
  dashboardUsers   DashboardUser[]
  deviceHealths    DeviceHealth[]
  lockGroups       LockGroup[]
  pendingSignups   PendingSignup[]
  people           Person[]
  pmsConnections   PmsConnection[]
  properties       Property[]
  staffMembers     StaffMember[]
  subscriptions    Subscription?
  ttlockAuth       TTLockAuth?
}

model DashboardUser {
  id                  String               @id @default(cuid())
  organizationId      String
  email               String               @unique
  passwordHash        String
  fullName            String?
  role                DashboardUserRole    @default(ORG_ADMIN)
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tokenVersion        Int                  @default(0)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId, isActive])
  @@index([organizationId, role])
}

model PasswordResetToken {
  id        String        @id @default(cuid())
  userId    String
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  user      DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Property {
  id                         String                      @id @default(cuid())
  organizationId             String
  name                       String
  address1                   String?
  city                       String?
  region                     String?
  country                    String?
  timezone                   String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  cleaningDurationMinutes    Int                         @default(180)
  cleaningStartOffsetMinutes Int                         @default(30)
  status                     String                      @default("ACTIVE")
  latitude                   Decimal?                    @db.Decimal(10, 7)
  longitude                  Decimal?                    @db.Decimal(10, 7)
  smartAutomationEnabled     Boolean                     @default(false)
  checkInTime                String?                     @db.VarChar(5)
  checkOutTime               String?                     @db.VarChar(5)
  automationExecutionLogs    AutomationExecutionLog[]
  automationRules            AutomationRule[]
  deviceHealths              DeviceHealth[]
  locks                      Lock[]
  organization               Organization                @relation(fields: [organizationId], references: [id])
  automationDevices          PropertyAutomationDevice[]
  automationSettings         PropertyAutomationSettings?
  propertyDevices            PropertyDevice[]
  reservations               Reservation[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model Lock {
  id             String          @id @default(cuid())
  ttlockLockId   Int             @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isActive       Boolean         @default(true)
  locationLabel  String?
  propertyId     String
  ttlockLockName String?
  displayName    String?
  sGrants        AccessGrant[]
  deviceHealth   DeviceHealth?
  property       Property        @relation(fields: [propertyId], references: [id])
  groups         LockGroupLock[]

  @@index([propertyId, isActive])
}

model Person {
  id               String              @id @default(cuid())
  organizationId   String
  role             PersonRole
  fullName         String
  email            String?
  phone            String?
  stripeCustomerId String?             @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  accessGrants     AccessGrant[]
  assignments      ManagerAssignment[]
  organization     Organization        @relation(fields: [organizationId], references: [id])
  subscriptions    Subscription[]

  @@index([organizationId, role])
}

model PendingSignup {
  id                      String              @id @default(cuid())
  email                   String
  passwordHash            String
  fullName                String?
  organizationName        String
  phone                   String?
  requestedLocks          Int                 @default(1)
  stripeCheckoutSessionId String?             @unique
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripePriceId           String?
  status                  PendingSignupStatus @default(PENDING)
  organizationId          String?
  completedAt             DateTime?
  expiresAt               DateTime?
  metadata                Json?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  organization            Organization?       @relation(fields: [organizationId], references: [id])

  @@index([email])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model Subscription {
  id                            String             @id @default(cuid())
  personId                      String?
  stripeSubscriptionId          String?            @unique
  status                        SubscriptionStatus
  currentPeriodStart            DateTime?
  currentPeriodEnd              DateTime?
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt
  graceUntil                    DateTime?
  organizationId                String             @unique
  stripeCustomerId              String?
  entitledLocks                 Int                @default(0)
  stripeSubscriptionItemId      String?
  entitledSmartProperties       Int                @default(0)
  stripeSmartSubscriptionItemId String?
  organization                  Organization       @relation(fields: [organizationId], references: [id])
  person                        Person?            @relation(fields: [personId], references: [id])

  @@index([personId, status])
  @@index([organizationId, status])
}

model Reservation {
  id                      String                   @id @default(cuid())
  propertyId              String
  guestName               String
  guestEmail              String?
  guestPhone              String?
  roomName                String?
  checkIn                 DateTime
  checkOut                DateTime
  paymentState            PaymentState             @default(NONE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  guestToken              String?                  @unique
  guestTokenExpiresAt     DateTime?
  ingestKey               String?                  @unique
  source                  String?
  externalId              String?
  externalProvider        String?
  externalRaw             Json?
  externalUpdatedAt       DateTime?
  lastIngestError         String?
  lastIngestedAt          DateTime?
  status                  ReservationStatus        @default(ACTIVE)
  lastHardwareSyncAt      DateTime?
  lastReconciledAt        DateTime?
  lastReconciledCheckIn   DateTime?
  lastReconciledCheckOut  DateTime?
  accessGrants            AccessGrant[]
  automationExecutionLogs AutomationExecutionLog[]
  guestLinkReminderLogs   GuestLinkReminderLog[]
  messageDispatchLogs     MessageDispatchLog[]
  NfcAssignment           NfcAssignment[]
  pmsLinks                PmsReservationLink[]
  property                Property                 @relation(fields: [propertyId], references: [id])
  staffAssignments        StaffAssignment[]

  @@unique([propertyId, externalProvider, externalId])
  @@index([propertyId, checkIn, checkOut])
}

model AccessCode {
  id               String   @id @default(cuid())
  lockId           Int
  method           String
  keyboardPwdId    String?
  startDate        BigInt
  endDate          BigInt
  phone            String?
  createdAt        DateTime @default(now())
  accessCodeEnc    String?
  accessCodeHash   String
  accessCodeMasked String
  expiresAt        DateTime

  @@index([lockId, createdAt])
  @@index([expiresAt])
  @@index([accessCodeHash])
}

model AccessGrant {
  id                         String           @id @default(cuid())
  lockId                     String
  personId                   String?
  reservationId              String?
  method                     AccessMethod
  status                     AccessStatus     @default(PENDING)
  startsAt                   DateTime
  endsAt                     DateTime
  unlockKey                  String?          @default("#")
  accessCodeMasked           String?
  ttlockKeyboardPwdId        Int?
  ttlockKeyId                Int?
  ttlockPayload              Json?
  linkedStripeEventId        String?
  linkedStripeCustomerId     String?
  linkedStripeSubscriptionId String?
  lastError                  String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  staffMemberId              String?
  ttlockRefId                String?          @db.VarChar(128)
  type                       AccessGrantType  @default(GUEST)
  desiredEndsAt              DateTime?
  desiredStartsAt            DateTime?
  lastAppliedAt              DateTime?
  revokedReason              String?
  lock                       Lock             @relation(fields: [lockId], references: [id])
  person                     Person?          @relation(fields: [personId], references: [id])
  reservation                Reservation?     @relation(fields: [reservationId], references: [id])
  staffMember                StaffMember?     @relation(fields: [staffMemberId], references: [id])
  messages                   MessageLog[]
  staffAssignment            StaffAssignment?

  @@index([lockId, status, startsAt, endsAt])
  @@index([personId, status])
  @@index([reservationId, status])
  @@index([type, staffMemberId])
  @@index([reservationId, method, type])
}

model StripeEventLog {
  id          String    @id @default(cuid())
  stripeId    String    @unique
  type        String
  livemode    Boolean?
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, processedAt])
}

model TTLockAuth {
  id             String       @id @default(cuid())
  organizationId String       @unique
  uid            Int?
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model LockGroup {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id])
  locks          LockGroupLock[]
  assignments    ManagerAssignment[]

  @@index([organizationId])
}

model LockGroupLock {
  id          String    @id @default(cuid())
  lockGroupId String
  lockId      String
  lockGroup   LockGroup @relation(fields: [lockGroupId], references: [id])
  lock        Lock      @relation(fields: [lockId], references: [id])

  @@unique([lockGroupId, lockId])
}

model DeviceHealth {
  id                 String               @id @default(cuid())
  organizationId     String
  propertyId         String?
  lockId             String               @unique
  battery            Int?
  gatewayConnected   Boolean?
  isOnline           Boolean?
  lastSyncAt         DateTime?
  lastEventAt        DateTime?
  lastSeenAt         DateTime?
  healthStatus       DeviceHealthStatus   @default(UNKNOWN)
  healthMessage      String?
  source             String?
  rawPayload         Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  hasActiveAccess    Boolean?
  nextCheckInAt      DateTime?
  operationalMessage String?
  operationalRisk    OperationalRiskLevel @default(UNKNOWN)
  recommendedAction  String?
  riskCalculatedAt   DateTime?
  lock               Lock                 @relation(fields: [lockId], references: [id], onDelete: Cascade)
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property?            @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([propertyId])
  @@index([healthStatus])
  @@index([operationalRisk])
  @@index([lastSeenAt])
  @@index([nextCheckInAt])
}

model ManagerAssignment {
  id          String    @id @default(cuid())
  personId    String
  lockGroupId String
  createdAt   DateTime  @default(now())
  lockGroup   LockGroup @relation(fields: [lockGroupId], references: [id])
  person      Person    @relation(fields: [personId], references: [id])

  @@unique([personId, lockGroupId])
}

model MessageLog {
  id                String       @id @default(cuid())
  channel           String
  to                String
  from              String?
  body              String
  provider          String
  providerMessageId String?
  status            String?
  accessGrantId     String?
  createdAt         DateTime     @default(now())
  error             String?
  retryCount        Int          @default(0)
  organizationId    String?
  propertyId        String?
  reservationId     String?
  accessGrant       AccessGrant? @relation(fields: [accessGrantId], references: [id])

  @@index([channel, to, createdAt])
  @@index([accessGrantId])
  @@index([reservationId])
  @@index([propertyId])
  @@index([organizationId])
  @@index([status, retryCount, createdAt])
  @@index([organizationId, propertyId, createdAt])
  @@index([organizationId, status, retryCount, createdAt])
}

model MessageDispatchLog {
  id            String      @id @default(cuid())
  reservationId String
  type          String
  channel       String
  status        String
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@index([reservationId, type])
}

model PrimeNotifyState {
  id             String   @id @default(cuid())
  organizationId String   @unique
  lastNotified   String
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model StaffMember {
  id             String            @id @default(cuid())
  organizationId String
  fullName       String
  phoneE164      String?
  photoUrl       String?
  companyName    String?
  isActive       Boolean           @default(true)
  ttlockCardRef  String?           @db.VarChar(128)
  ttlockUserRef  String?           @db.VarChar(128)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  grants         AccessGrant[]
  assignments    StaffAssignment[]
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive])
  @@index([phoneE164])
}

model StaffAssignment {
  id            String                @id @default(cuid())
  reservationId String
  staffMemberId String
  method        StaffAccessMethod     @default(NFC_TIMEBOUND)
  startsAt      DateTime
  endsAt        DateTime
  status        StaffAssignmentStatus @default(SCHEDULED)
  lastError     String?
  retryCount    Int                   @default(0)
  accessGrantId String?               @unique
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  accessGrant   AccessGrant?          @relation(fields: [accessGrantId], references: [id])
  reservation   Reservation           @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  staffMember   StaffMember           @relation(fields: [staffMemberId], references: [id])

  @@unique([reservationId, staffMemberId])
  @@index([reservationId])
  @@index([staffMemberId])
  @@index([status, startsAt, endsAt])
}

model GuestLinkReminderLog {
  id            String       @id @default(cuid())
  reservationId String
  channel       String       @default("sms")
  createdAt     DateTime     @default(now())
  error         String?
  kind          ReminderKind @default(CHECKIN_LINK)
  provider      String?
  providerMsgId String?
  status        String       @default("SENT")
  to            String
  reservation   Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, kind])
  @@index([to, createdAt])
}

model NfcCard {
  id            String          @id @default(cuid())
  propertyId    String
  label         String?
  ttlockCardId  Int
  status        NfcCardStatus   @default(AVAILABLE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  NfcAssignment NfcAssignment[]

  @@unique([propertyId, ttlockCardId])
  @@index([propertyId, status])
}

model NfcAssignment {
  id            String              @id @default(cuid())
  reservationId String
  nfcCardId     String
  role          NfcAssignmentRole
  status        NfcAssignmentStatus @default(ACTIVE)
  startsAt      DateTime
  endsAt        DateTime
  lastError     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  NfcCard       NfcCard             @relation(fields: [nfcCardId], references: [id])
  Reservation   Reservation         @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([nfcCardId, status])
  @@index([reservationId, status])
}

model PmsConnection {
  id                   String               @id @default(cuid())
  organizationId       String
  provider             PmsProvider
  status               PmsConnectionStatus  @default(ACTIVE)
  credentialsEncrypted String?
  webhookSecret        String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listings             PmsListing[]
  reservationLinks     PmsReservationLink[]
  webhookEvents        WebhookEventIngest[]

  @@unique([organizationId, provider])
  @@index([organizationId, provider])
}

model PmsListing {
  id                String        @id @default(cuid())
  connectionId      String
  externalListingId String
  name              String?
  metadata          Json?
  propertyId        String?
  lockId            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  connection        PmsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalListingId])
  @@index([connectionId])
  @@index([propertyId])
  @@index([lockId])
}

model PmsReservationLink {
  id                    String        @id @default(cuid())
  connectionId          String
  externalReservationId String
  reservationId         String
  lastSeenAt            DateTime      @default(now())
  canonicalHash         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  connection            PmsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  reservation           Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalReservationId])
  @@index([reservationId])
}

model WebhookEventIngest {
  id              String             @id @default(cuid())
  connectionId    String
  provider        PmsProvider
  eventType       String
  externalEventId String?
  payloadRaw      Json
  status          WebhookEventStatus @default(PENDING)
  attempts        Int                @default(0)
  lastError       String?
  receivedAt      DateTime           @default(now())
  processedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  connection      PmsConnection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalEventId])
  @@index([connectionId, status])
  @@index([provider])
  @@index([receivedAt])
}

model PropertyDevice {
  id             String         @id @default(cuid())
  organizationId String
  propertyId     String
  name           String
  type           String
  provider       String
  externalId     String?
  isActive       Boolean        @default(true)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  actions        DeviceAction[]
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([organizationId, propertyId])
  @@index([propertyId, isActive])
  @@index([organizationId, provider])
}

model AutomationRule {
  id             String         @id @default(cuid())
  organizationId String
  propertyId     String
  trigger        String
  offsetMinutes  Int?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actions        DeviceAction[]

  @@index([organizationId, propertyId, trigger, isActive])
}

model DeviceAction {
  id        String         @id @default(cuid())
  ruleId    String
  deviceId  String
  action    String
  value     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @default(now()) @updatedAt
  device    PropertyDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([deviceId])
}

model IntegrationAccount {
  id             String    @id @default(cuid())
  organizationId String
  provider       String
  status         String
  externalUid    String?
  linkedAt       DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, provider])
}

model AutomationExecution {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String
  reservationId  String
  trigger        String
  executedAt     DateTime @default(now())

  @@unique([reservationId, trigger])
  @@index([organizationId, propertyId])
}

model PropertyAutomationSettings {
  id                     String   @id @default(cuid())
  organizationId         String
  propertyId             String   @unique
  arrivalOffsetMinutes   Int      @default(30)
  departureOffsetMinutes Int      @default(15)
  automationEnabled      Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  guestExperienceDevices Json?
  guestExperienceEnabled Boolean  @default(true)
  property               Property @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
}

model PropertyAutomationDevice {
  id                String    @id @default(cuid())
  organizationId    String
  propertyId        String
  provider          String
  externalDeviceId  String
  deviceName        String
  deviceCategory    String?
  isEnabled         Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  autoOffAtCheckOut Boolean   @default(true)
  autoOnAtCheckIn   Boolean   @default(true)
  deviceProfile     String?
  profileDetectedAt DateTime?
  profileSource     String?
  tuyaFunctions     Json?
  property          Property  @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, externalDeviceId])
  @@index([organizationId])
  @@index([propertyId])
}

model AutomationExecutionLog {
  id             String       @id @default(cuid())
  organizationId String
  propertyId     String
  reservationId  String?
  trigger        String
  source         String
  deviceName     String?
  deviceCategory String?
  externalId     String?
  action         String?
  value          Json?
  status         String
  errorMessage   String?
  executedAt     DateTime     @default(now())
  property       Property     @relation(fields: [propertyId], references: [id])
  reservation    Reservation? @relation(fields: [reservationId], references: [id])

  @@index([organizationId, propertyId])
  @@index([organizationId, trigger])
  @@index([organizationId, executedAt])
  @@index([propertyId, executedAt])
  @@index([reservationId])
  @@index([status, executedAt])
}

enum ReminderKind {
  CHECKIN_LINK
}

enum PersonRole {
  MANAGER
  GUEST
  STAFF
}

enum PendingSignupStatus {
  PENDING
  CHECKOUT_CREATED
  COMPLETED
  EXPIRED
  CANCELED
  FAILED
}

enum DashboardUserRole {
  ADMIN
  MEMBER
  PLATFORM_ADMIN
  ORG_ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum ReservationStatus {
  ACTIVE
  CANCELLED
}

enum AccessMethod {
  PASSCODE_TIMEBOUND
  AUTHORIZED_ADMIN
}

enum AccessStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
  FAILED
}

enum AccessGrantType {
  GUEST
  STAFF
}

enum StaffAccessMethod {
  NFC_TIMEBOUND
  EKEY_TIMEBOUND
}

enum StaffAssignmentStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum PaymentState {
  NONE
  PAID
  REFUNDED
}

enum NfcCardStatus {
  AVAILABLE
  ASSIGNED
  LOST
  RETIRED
}

enum NfcAssignmentStatus {
  ACTIVE
  ENDED
  FAILED
}

enum NfcAssignmentRole {
  GUEST
  CLEANING
}

enum DeviceHealthStatus {
  HEALTHY
  WARNING
  OFFLINE
  LOW_BATTERY
  UNKNOWN
}

enum OperationalRiskLevel {
  HEALTHY
  WARNING
  AT_RISK
  CRITICAL
  UNKNOWN
}

enum PmsProvider {
  CLOUDBEDS
  GUESTY
  HOSTAWAY
  LODGIFY
  GENERIC
}

enum PmsConnectionStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum WebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DEAD
}
