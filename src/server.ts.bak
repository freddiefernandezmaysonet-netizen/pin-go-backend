app.post("/debug/ttlock/create-passcode", async (req, res) => {
  try {
    const { lockId, code, minutes } = req.body ?? {};

    if (!lockId || !code) {
      return res.status(400).json({ ok: false, error: "Missing lockId or code" });
    }

    const mins = Number(minutes ?? 30);
    if (!Number.isFinite(mins) || mins <= 0) {
      return res.status(400).json({ ok: false, error: "minutes must be a positive number" });
    }

    const startDate = Date.now();
    const endDate = startDate + mins * 60 * 1000;

    const data = await ttlockCreatePasscode({
      lockId: Number(lockId),
      code: String(code),
      startDate,
      endDate,
    });

    return res.json({
      ok: true,
      lockId: Number(lockId),
      codeMasked: String(code).slice(0, 2) + "****",
      minutes: mins,
      startDate,
      endDate,
      ttlock: data,
    });
  } catch (e: any) {
    console.error("create-passcode error:", e?.message ?? e);
    return res.status(500).json({ ok: false, error: e?.message ?? "TTLock create passcode failed" });
  }
});


// =====================
// TTLock -> Prisma Sync
// =====================
app.post("/debug/ttlock/sync-locks", async (req, res) => {
  try {
    const { propertyId } = req.body ?? {};
    if (!propertyId) {
      return res.status(400).json({ ok: false, error: "Missing propertyId" });
    }

    // 1) Verifica que la propiedad exista
    const prop = await prisma.property.findUnique({ where: { id: String(propertyId) } });
    if (!prop) return res.status(404).json({ ok: false, error: "Property not found" });

    // 2) Trae locks desde TTLock
    const result = await ttlockListLocks({ pageNo: 1, pageSize: 50 });
    const list = result.list ?? [];

    // 3) Upsert en Prisma (Lock) por ttlockLockId
    let created = 0;
    let updated = 0;

    for (const l of list) {
      const lockId = Number(l.lockId);
      const lockName = String(l.lockAlias ?? l.lockName ?? l.lockName ?? "");

      const existing = await prisma.lock.findUnique({ where: { ttlockLockId: lockId } });

      if (!existing) {
        await prisma.lock.create({
          data: {
            propertyId: prop.id,
            ttlockLockId: lockId,
            ttlockLockName: lockName || null,
            locationLabel: null,
          },
        });
        created++;
      } else {
        await prisma.lock.update({
          where: { ttlockLockId: lockId },
          data: {
            propertyId: prop.id, // por si quieres “mover” el lock a esta propiedad
            ttlockLockName: lockName || existing.ttlockLockName,
          },
        });
        updated++;
      }
    }

    return res.json({ ok: true, propertyId: prop.id, totalFromTTLock: list.length, created, updated });
  } catch (e: any) {
    console.error("sync-locks error:", e?.message ?? e);
    return res.status(500).json({ ok: false, error: e?.message ?? "sync-locks failed" });
  }
});

