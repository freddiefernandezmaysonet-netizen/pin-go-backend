  try {
    const { propertyId } = req.body ?? {};
    if (!propertyId) return res.status(400).json({ ok: false, error: "Missing propertyId" });

    // 1) Verifica property existe
    const property = await prisma.property.findUnique({ where: { id: String(propertyId) } });
    if (!property) return res.status(404).json({ ok: false, error: "Property not found" });

    // 2) Trae locks de TTLock
    const remote = await ttlockListLocks(1, 50);

    let created = 0;
    let updated = 0;

    for (const l of remote.list) {
      const ttlockLockId = Number(l.lockId);
      const lockName = String(l.lockAlias ?? l.lockName ?? "");

      const up = await prisma.lock.upsert({
        where: { ttlockLockId },
        create: {
          propertyId: property.id,
          ttlockLockId,
          ttlockLockName: lockName || null,
          locationLabel: null,
          isActive: true,
        },
        update: {
          propertyId: property.id,
          ttlockLockName: lockName || null,
          isActive: true,
        },
      });

      // Cuenta created/updated aproximado (si quieres exactitud hay que chequear existía antes)
      if (up.createdAt.getTime() === up.updatedAt.getTime()) created++;
      else updated++;
    }

    return res.json({ ok: true, totalRemote: remote.total, created, updated });
  } catch (e: any) {
    console.error("sync-locks error:", e?.message ?? e);
    return res.status(500).json({ ok: false, error: e?.message ?? "sync-locks error" });
  }
});

