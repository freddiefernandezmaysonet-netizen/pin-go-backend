// =====================
// Billing: Checkout (Prime subscription)
// =====================
app.post("/billing/checkout", async (req, res) => {
  try {
    const { personId, email, phone } = req.body ?? {};
    if (!personId) return res.status(400).json({ ok: false, error: "Missing personId" });

    // si ya tiene ACTIVE, no hagas otro checkout
    const existingActive = await prisma.subscription.findFirst({
      where: { personId: String(personId), status: "ACTIVE" },
      orderBy: { updatedAt: "desc" },
    });

if (existingActive) {
  // Si está ACTIVE -> manda al Billing Portal (manejar suscripción)
  const person = await prisma.person.findUnique({ where: { id: String(personId) } });
  if (!person) return res.status(404).json({ ok: false, error: "Person not found" });
  if (!person.stripeCustomerId) {
    return res.status(400).json({ ok: false, error: "No stripeCustomerId yet for this person" });
  }

  const baseReturn = process.env.BILLING_RETURN_URL || "http://127.0.0.1:3000";
  if (!/^https?:\/\//i.test(baseReturn)) {
    return res.status(500).json({ ok: false, error: "Invalid BILLING_RETURN_URL (must start with http/https)" });
  }

  const portal = await stripe.billingPortal.sessions.create({
    customer: person.stripeCustomerId,
    return_url: `${baseReturn}?from=portal`,
  });

  return res.json({
    ok: true,
    alreadyActive: true,
    stripeSubscriptionId: existingActive.stripeSubscriptionId,
    portalUrl: portal.url,
    message: "Prime is ACTIVE. Use portalUrl to manage subscription.",
  });
}

    
    if (!PRIME_PRICE_ID) {
      return res.status(500).json({ ok: false, error: "Missing PIN_GO_PRIME_PRICE_ID in .env" });
    }

    if (!/^https?:\/\//i.test(BILLING_RETURN_URL)) {
      return res.status(500).json({
        ok: false,
        error: `Invalid BILLING_RETURN_URL="${BILLING_RETURN_URL}". Must start with http:// or https://`,
      });
    }

    const person = await prisma.person.findUnique({ where: { id: String(personId) } });
    if (!person) return res.status(404).json({ ok: false, error: "Person not found" });

    let customerId = person.stripeCustomerId ?? null;

    if (!customerId) {
      const customer = await stripe.customers.create({
        email: email ?? person.email ?? undefined,
        phone: phone ?? person.phone ?? undefined,
        metadata: { personId: person.id },
      });

      customerId = customer.id;

      await prisma.person.update({
        where: { id: person.id },
        data: { stripeCustomerId: customerId },
      });
    }

    const checkoutSession = await stripe.checkout.sessions.create({
      mode: "subscription",
      customer: customerId,
      line_items: [{ price: PRIME_PRICE_ID, quantity: 1 }],
      success_url: `${BILLING_RETURN_URL}/success?session_id={CHECKOUT_SESSION_ID}`,
      cancel_url: `${BILLING_RETURN_URL}/cancel`,
      subscription_data: { metadata: { personId: person.id } },
      allow_promotion_codes: true,
    });

    return res.json({
      ok: true,
      url: checkoutSession.url, // <- aquí va el URL
      sessionId: checkoutSession.id,
      customerId,
    });
  } catch (e: any) {
    console.error("billing/checkout error:", e?.message ?? e);
    return res.status(500).json({ ok: false, error: e?.message ?? "Checkout error" });
  }
});

app.post("/billing/checkout/force", async (req, res) => {
  try {
    const { personId, email, phone } = req.body ?? {};
    if (!personId) return res.status(400).json({ ok: false, error: "Missing personId" });

    if (!PRIME_PRICE_ID) return res.status(500).json({ ok: false, error: "Missing PIN_GO_PRIME_PRICE_ID in .env" });

    if (!priceId) return res.status(500).json({ ok: false, error: "Missing PIN_GO_PRIME_PRICE_ID in .env" });

    const baseReturn = process.env.BILLING_RETURN_URL || "http://127.0.0.1:3000/prime";
    if (!/^https?:\/\//i.test(baseReturn)) {
      return res.status(500).json({ ok: false, error: "Invalid BILLING_RETURN_URL (must start withhttp/https)" }); 
    }

    const person = await prisma.person.findUnique({ where: { id: String(personId) } });
    if (!person) return res.status(404).json({ ok: false, error: "Person not found" });

    let customerId = person.stripeCustomerId ?? null;
    if (!customerId) {
      const customer = await stripe.customers.create({
        email: email ?? person.email ?? undefined,
        phone: phone ?? person.phone ?? undefined,
        metadata: { personId: person.id },
      });
      customerId = customer.id;
      await prisma.person.update({ where: { id: person.id }, data: { stripeCustomerId: customerId } });
    }

    const session = await stripe.checkout.sessions.create({
      mode: "subscription",
      customer: customerId,
      line_items: [{ price: PRIME_PRICE_ID, quantity: 1 }],
      success_url: `${baseReturn}/success?session_id={CHECKOUT_SESSION_ID}`,
      cancel_url: `${baseReturn}/cancel`,
      subscription_data: { metadata: { personId: person.id } },
      allow_promotion_codes: true,
    });

    return res.json({ ok: true, url: session.url, sessionId: session.id, customerId });
  } catch (e: any) {
    console.error("billing/checkout/force error:", e?.message ?? e);
    return res.status(500).json({ ok: false, error: e?.message ?? "Checkout force error" });
  }
});

// =====================
// Billing: Portal (manage subscription)
// =====================
app.post("/billing/portal", async (req, res) => {
  try {
    const { personId } = req.body ?? {};
    if (!personId) return res.status(400).json({ ok: false, error: "Missing personId" });

    const person = await prisma.person.findUnique({ where: { id: String(personId) } });
    if (!person) return res.status(404).json({ ok: false, error: "Person not found" });
    if (!person.stripeCustomerId)
      return res.status(400).json({ ok: false, error: "No stripeCustomerId yet for this person" });

    if (!/^https?:\/\//i.test(BILLING_RETURN_URL)) {
      return res.status(500).json({ ok: false, error: "Invalid BILLING_RETURN_URL" });
    }

    const portalSession = await stripe.billingPortal.sessions.create({
      customer: person.stripeCustomerId,
      return_url: `${BILLING_RETURN_URL}?from=portal`,
    });

    return res.json({ ok: true, url: portalSession.url });
  } catch (e: any) {
    console.error("billing/portal error:", e?.message ?? e);
    return res.status(500).json({ ok: false, error: e?.message ?? "Portal error" });
  }
});

// =====================
// Prime enforcement scheduler (safe)
// =====================
async function enforcePrime() {
  try {
    const cutoff = new Date(Date.now() - PRIME_GRACE_HOURS * 60 * 60 * 1000);

    const updated = await prisma.subscription.updateMany({
      where: { status: "INCOMPLETE", createdAt: { lt: cutoff } },
      data: { status: "PAST_DUE" },
    });

    if (updated.count > 0) {
      console.log(`✅ Prime enforce: marked PAST_DUE=${updated.count} (reason=INCOMPLETE_GRACE_EXPIRED)`);
    }
  } catch (e: any) {
    console.error("❌ Prime enforce loop error:", e?.message ?? e);
  }
}

console.log(
  `⏱️ Prime enforcement scheduler: every ${PRIME_ENFORCE_INTERVAL_MINUTES} minutes (grace=${PRIME_GRACE_HOURS}h)`
);

setInterval(() => {
  void enforcePrime();
}, PRIME_ENFORCE_INTERVAL_MINUTES * 60 * 1000);

// =====================
// Access: Guest (passcode timebound - STUB)
// =====================
app.post("/access/guest", async (req, res) => {
  try {
    const { ttlockLockId, roomName, guestName, guestEmail, guestPhone, checkIn, checkOut } = req.body ?? {};

    if (!ttlockLockId || !guestName || !roomName || !checkIn || !checkOut) {
      return res.status(400).json({
        ok: false,
        error: "Missing required fields: ttlockLockId, roomName, guestName, checkIn, checkOut",
      });
    }

    const start = new Date(checkIn);
    const end = new Date(checkOut);

    if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
      return res.status(400).json({ ok: false, error: "Invalid checkIn/checkOut date format (use ISO string)." });
    }
    if (end <= start) {
      return res.status(400).json({ ok: false, error: "checkOut must be after checkIn." });
    }

    const lock = await prisma.lock.findUnique({ where: { ttlockLockId: Number(ttlockLockId) } });
    if (!lock) {
      return res.status(404).json({ ok: false, error: `Lock not found for ttlockLockId=${ttlockLockId}` });
    }

    const reservation = await prisma.reservation.create({
      data: {
        propertyId: lock.propertyId,
        guestName,
        guestEmail: guestEmail ?? null,
        guestPhone: guestPhone ?? null,
        roomName,
        checkIn: start,
        checkOut: end,
        paymentState: "NONE",
      },
    });

    const unlockKey = "#";
    const codePlaceholder = "TBD";

    const accessGrant = await prisma.accessGrant.create({
      data: {
        lockId: lock.id,
        reservationId: reservation.id,
        method: "PASSCODE_TIMEBOUND",
        status: "PENDING",
        startsAt: start,
        endsAt: end,
        unlockKey,
        accessCodeMasked: null,
        ttlockPayload: { roomName, note: "pending ttlock generation" },
      },
    });

    const msg = buildAccessMessage({
      roomName,
      code: `${codePlaceholder}${unlockKey}`,
      unlockKeyHint: unlockKey,
      start,
      end,
      brand: "Pin&Go",
    });

    return res.json({ ok: true, reservation, accessGrant, message: msg });
  } catch (e: any) {
    console.error(e);
    return res.status(500).json({ ok: false, error: e?.message ?? "Internal error" });
  }
});

// =====================
// Access: Admin (Authorized Admin - STUB)
// =====================
app.post("/access/admin", async (req, res) => {
  try {
    const { ttlockLockId, fullName, email, phone, startsAt, endsAt } = req.body ?? {};

    if (!ttlockLockId || !fullName) {
      return res.status(400).json({ ok: false, error: "Missing required fields: ttlockLockId, fullName" });
    }

    const start = startsAt ? new Date(startsAt) : new Date();
    const end = endsAt ? new Date(endsAt) : new Date(Date.now() + 365 * 24 * 60 * 60 * 1000);

    const lock = await prisma.lock.findUnique({ where: { ttlockLockId: Number(ttlockLockId) } });
    if (!lock) return res.status(404).json({ ok: false, error: `Lock not found for ttlockLockId=${ttlockLockId}` });

    const org = await prisma.organization.findFirst({ where: { id: "pingo-org-1" } });
    if (!org) return res.status(500).json({ ok: false, error: "Org not found" });

    const person = await prisma.person.create({
      data: {
        organizationId: org.id,
        role: "MANAGER",
        fullName,
        email: email ?? null,
        phone: phone ?? null,
      },
    });

    const grant = await prisma.accessGrant.create({
      data: {
        lockId: lock.id,
        personId: person.id,
        method: "AUTHORIZED_ADMIN",
        status: "PENDING",
        startsAt: start,
        endsAt: end,
        unlockKey: "#",
        ttlockPayload: { channel: "TTLock Authorized Admin", note: "Pending admin authorization" },
      },
    });

    return res.json({ ok: true, person, accessGrant: grant });
  } catch (e: any) {
    console.error(e);
    return res.status(500).json({ ok: false, error: e?.message ?? "Internal error" });
  }
});

app.listen(PORT, () => console.log(`🚀 Pin&Go API running on http://localhost:${PORT}`));

