import "dotenv/config";
import express from "express";
import bodyParser from "body-parser";
import Stripe from "stripe";
import { PrismaClient } from "@prisma/client";
import stripe from "./billing/stripe"; // ✅ default export
import { buildAccessMessage } from "./util/accessMessage.js";
import { ttlockGetAccessToken } from "./ttlock/ttlock.service";
import { ttlockListLocks } from "./ttlock/ttlock.api";
import { ttlockCreatePasscode } from "./ttlock/ttlock.passcode";

const app = express();
const prisma = new PrismaClient();

const PORT = Number(process.env.PORT ?? 3000);

// =====================
// Prime Config (Amazon Prime-style)
// =====================
const PRIME_GRACE_HOURS = Number(process.env.PRIME_GRACE_HOURS ?? 48);
const PRIME_ENFORCE_INTERVAL_MINUTES = Number(process.env.PRIME_ENFORCE_INTERVAL_MINUTES ?? 15);
const PRIME_SUSPEND_ON_PAYMENT_FAILED =
  String(process.env.PRIME_SUSPEND_ON_PAYMENT_FAILED ?? "0") === "1";

const PRIME_PRICE_ID = process.env.PIN_GO_PRIME_PRICE_ID ?? "";
const BILLING_RETURN_URL =
  process.env.BILLING_RETURN_URL ?? "http://127.0.0.1:3000/prime";

const STRIPE_WEBHOOK_SECRET = process.env.STRIPE_WEBHOOK_SECRET ?? "";

// =====================
// Stripe Webhook (MUST be before express.json)
// =====================
app.post(
  "/webhooks/stripe",
  bodyParser.raw({ type: "application/json" }),
  async (req, res) => {
    const sig = req.headers["stripe-signature"] as string | undefined;

    try {
      if (!sig) return res.status(400).send("Missing Stripe-Signature header");
      if (!STRIPE_WEBHOOK_SECRET)
        return res.status(500).send("Missing STRIPE_WEBHOOK_SECRET in .env");

      let event: Stripe.Event;

      try {
        event = stripe.webhooks.constructEvent(req.body, sig, STRIPE_WEBHOOK_SECRET);
      } catch (err: any) {
        console.error("❌ Stripe webhook signature verification failed:", err?.message ?? err);
        return res.status(400).send(`Webhook Error: ${err?.message ?? "Invalid signature"}`);
      }

      switch (event.type) {
        // 1) Checkout terminado => DB aprende el subId real
        case "checkout.session.completed": {
          const sessionObj = event.data.object as Stripe.Checkout.Session;

          const personId = sessionObj.metadata?.personId;
          const subId = sessionObj.subscription as string | null;
          const customerId = sessionObj.customer as string | null;

          if (!personId || !subId) break;

          if (customerId) {
            await prisma.person.update({
              where: { id: personId },
              data: { stripeCustomerId: customerId },
            });
          }

          await prisma.subscription.upsert({
            where: { stripeSubscriptionId: subId },
            create: {
              personId,
              stripeSubscriptionId: subId,
              status: "INCOMPLETE",
            },
            update: {
              personId,
              status: "INCOMPLETE",
            },
          });

          break;
        }

        // 2) Pago OK => ACTIVE + periodos
        case "invoice.paid": {
          const invoice = event.data.object as Stripe.Invoice;
          const subId = invoice.subscription as string | null;

          if (subId) {
            const sub = await stripe.subscriptions.retrieve(subId);

            await prisma.subscription.updateMany({
              where: { stripeSubscriptionId: subId },
              data: {
                status: "ACTIVE",
                currentPeriodStart: new Date(sub.current_period_start * 1000),
                currentPeriodEnd: new Date(sub.current_period_end * 1000),
              },
            });
          }
          break;
        }

        // 3) Falló pago => PAST_DUE
        case "invoice.payment_failed": {
          const invoice = event.data.object as Stripe.Invoice;
          const subId = invoice.subscription as string | null;

          if (subId) {
            await prisma.subscription.updateMany({
              where: { stripeSubscriptionId: subId },
              data: { status: "PAST_DUE" },
            });

            if (PRIME_SUSPEND_ON_PAYMENT_FAILED) {
              // (futuro) suspender acceso inmediatamente
            }
          }
          break;
        }

        // 4) Cancelado => CANCELED
        case "customer.subscription.deleted": {
          const sub = event.data.object as Stripe.Subscription;

          await prisma.subscription.updateMany({
            where: { stripeSubscriptionId: sub.id },
            data: { status: "CANCELED" },
          });

          break;
        }

        default:
          break;
      }

      return res.json({ received: true });
    } catch (e: any) {
      console.error("❌ Stripe webhook handler error:", e?.message ?? e);
      return res.status(500).json({ error: e?.message ?? "Webhook handler failed" });
    }
  }
);

// =====================
// JSON middleware (after webhook)
// =====================
app.use(express.json());

